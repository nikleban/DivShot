{
  "manifest_version": 3,
  "name": "DivShot",
  "version": "0.1.0",
  "description": "Select any page element and screenshot it.",
  "permissions": ["activeTab", "scripting", "tabs", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Select element"
  }
}
